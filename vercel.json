{
  "version": 2,
  "functions": {
    "api/index.py": {
      "runtime": "@vercel/python@3"
    }
  },
  "routes": [
    {
      "src": "/api",
      "dest": "api/index.py"
    },
    {
      "src": "/api/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/",
      "dest": "frontend/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/$1"
    }
  ]
}
